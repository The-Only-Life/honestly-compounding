{
  "name": "honestly-compounding",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "bun --cwd apps/web run dev",
    "dev:server": "bun --cwd apps/server run dev",
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:server\"",
    "build:web": "bun --cwd apps/web run build",
    "build:server": "bun --cwd apps/server run build",
    "build": "bun run build:web && bun run build:server",
    "start": "concurrently \"bun --cwd apps/web run preview\" \"bun --cwd apps/server run start\"",
    "lint": "bun --cwd apps/web run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@supabase/supabase-js": "^2.75.0",
    "esbuild": "0.21.5"
  }
}