// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum AppRole {
  admin
  sponsor
  subscriber
}

enum ContactMethod {
  email
  phone
}

enum WaitlistStatus {
  pending
  invited
}

// User profiles table (maps to Supabase auth.users)
model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  fullName      String   @map("full_name")
  mobileNumber  String   @map("mobile_number")
  emailVerified Boolean? @default(false) @map("email_verified")
  isEnabled     Boolean? @default(false) @map("is_enabled")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  userRoles             UserRole[]
  themesCreated         Theme[]          @relation("ThemeCreator")
  bucketsCreated        Bucket[]         @relation("BucketCreator")
  stocksCreated         Stock[]          @relation("StockCreator")
  contentAccessGranted  ContentAccess[]  @relation("ContentAccessGrantor")
  contentAccessReceived ContentAccess[]  @relation("ContentAccessReceiver")
  auditLogs             AuditLog[]
  userSessions          UserSession[]
  userMetadata          UserMetadata?

  @@map("profiles")
}

// User metadata table
model UserMetadata {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @map("user_id") @db.Uuid
  role           AppRole?
  accessApproved Boolean?       @default(false) @map("access_approved")
  createdAt      DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  invitedBy      String?        @map("invited_by") @db.Uuid
  contactMethod  ContactMethod? @map("contact_method")

  // Relations
  profile Profile @relation(fields: [userId], references: [userId], map: "user_metadata_user_id_fkey")

  @@map("user_metadata")
}

// User roles table
model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      AppRole
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  profile Profile @relation(fields: [userId], references: [userId], map: "user_roles_user_id_fkey")

  @@map("user_roles")
}

// Investment themes table
model Theme {
  id          String   @id
  name        String   @unique
  description String   @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  // Relations
  creator Profile @relation("ThemeCreator", fields: [createdBy], references: [userId], onDelete: Restrict, map: "themes_creator_fkey")
  stocks  Stock[]

  @@index([createdBy], name: "idx_themes_created_by")
  @@index([createdAt], name: "idx_themes_created_at")
  @@map("themes")
}

// Buckets table (formerly risk buckets)
model Bucket {
  id          String   @id
  name        String   @unique
  description String   @db.Text
  riskMeasure String   @map("risk_measure")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  // Relations
  creator Profile @relation("BucketCreator", fields: [createdBy], references: [userId], onDelete: Restrict, map: "buckets_creator_fkey")
  stocks  Stock[]

  @@index([createdBy], name: "idx_buckets_created_by")
  @@index([createdAt], name: "idx_buckets_created_at")
  @@map("buckets")
}

// Stocks table
model Stock {
  id          String   @id
  symbol      String   @unique
  companyName String   @map("company_name")
  themeId     String   @map("theme_id")
  bucketId    String   @map("bucket_id")
  pdfUrl      String?  @map("pdf_url")
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(3)

  // Relations
  theme   Theme   @relation(fields: [themeId], references: [id], onDelete: Restrict, map: "stocks_theme_fkey")
  bucket  Bucket  @relation(fields: [bucketId], references: [id], onDelete: Restrict, map: "stocks_bucket_fkey")
  creator Profile @relation("StockCreator", fields: [createdBy], references: [userId], onDelete: Restrict, map: "stocks_creator_fkey")

  @@index([themeId], name: "idx_stocks_theme_id")
  @@index([bucketId], name: "idx_stocks_bucket_id")
  @@index([createdBy], name: "idx_stocks_created_by")
  @@map("stocks")
}

// Content access table
model ContentAccess {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  contentType String   @map("content_type") // 'stock', 'theme', 'bucket'
  contentId   String   @map("content_id") @db.Uuid
  grantedBy   String   @map("granted_by") @db.Uuid
  grantedAt   DateTime @default(now()) @map("granted_at") @db.Timestamptz(6)

  // Relations
  user    Profile @relation("ContentAccessReceiver", fields: [userId], references: [userId], map: "content_access_user_id_fkey")
  grantor Profile @relation("ContentAccessGrantor", fields: [grantedBy], references: [userId], map: "content_access_granted_by_fkey")

  @@map("content_access")
}

// Audit logs table
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id") @db.Uuid
  ipAddress    String?  @map("ip_address") @db.Inet
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  user Profile? @relation(fields: [userId], references: [userId], map: "audit_logs_user_id_fkey")

  @@map("audit_logs")
}

// User sessions table
model UserSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  loginAt   DateTime  @default(now()) @map("login_at") @db.Timestamptz(6)
  logoutAt  DateTime? @map("logout_at") @db.Timestamptz(6)
  ipAddress String?   @map("ip_address") @db.Inet
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  profile Profile @relation(fields: [userId], references: [userId], map: "user_sessions_user_id_fkey")

  @@map("user_sessions")
}

// Waitlist table
model Waitlist {
  id        String          @id @default(uuid()) @db.Uuid
  email     String          @unique
  status    WaitlistStatus  @default(pending)
  createdAt DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("waitlist")
}